# Speech-to-Text (Deepgram v1 streaming)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
STT_MODEL_WINNER=nova-3

# LLM (Groq — using llama-3.3-70b-versatile with instant fallback)
GROQ_API_KEY=your_groq_api_key_here

# Text-to-Speech (ElevenLabs Flash v2.5 — Urdu voice)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_flash_v2_5

# Database (Supabase) — include both old and new key names
SUPABASE_URL=https://your-project.supabase.co
# Old naming
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# New naming (2026 standard)
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_secret_key_here

# App & Database Settings
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres
APP_ENV=development
APP_NAME=Restaurant AI
DEBUG=True
